# This is an example environment file.
# Copy this file to .dev.vars and fill in your actual values.
# Do NOT commit .dev.vars to version control.

# Runtime environment — set to 'test' in test runners to skip external checks
ENVIRONMENT=development

# A secret string used to sign and encrypt cookies and tokens.
# Generate a long, random string for this.
BETTER_AUTH_SECRET="your-super-secret-key"

# The base URL of your application.
BETTER_AUTH_URL="http://localhost:4321"

# PUBLIC_ prefix makes this available to client-side code via import.meta.env
PUBLIC_BETTER_AUTH_URL="http://localhost:4321"

# Google OAuth Credentials for social login.
# Obtain from Google Cloud Console → APIs & Services → Credentials.
# Set Authorized redirect URI to: http://localhost:4321/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# GitHub OAuth Credentials for social login.
# Obtain from GitHub → Settings → Developer Settings → OAuth Apps.
# Set Authorization callback URL to: http://localhost:4321/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Cloudflare Turnstile — bot protection for login, signup, forgot-password.
# Dashboard: https://dash.cloudflare.com → Turnstile
# For local dev testing use the always-pass test keys:
PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# ── Email Provider ─────────────────────────────────────────────────────────────
# Choose 'resend' (recommended — requires a verified domain) or
# 'atlas' (Gmail SMTP fallback via the Atlas Mailer microservice, no domain needed).
# Leave unset to disable email sending in development (OTP will print to terminal).
EMAIL_PROVIDER=resend

# ── Resend (primary) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
# For production: verify your sending domain at https://resend.com/domains.
# RESEND_FROM must match your verified domain, e.g. "Meterly <noreply@yourdomain.com>".
# In development without a domain, use: "Meterly <onboarding@resend.dev>" — this only
# works with Resend's test addresses (delivered@resend.dev etc.), not real recipients.
RESEND_API_KEY="re_..."
RESEND_FROM="Meterly <noreply@yourdomain.com>"

# ── Atlas Mailer (fallback) ────────────────────────────────────────────────────
# Only required when EMAIL_PROVIDER=atlas.
# Deploy the Atlas Mailer Cloudflare Worker microservice (see Reference/README.md)
# and paste its URL and shared secret below.
ATLAS_MAILER_URL="https://your-atlas-mailer.workers.dev"
ATLAS_MAILER_SECRET="your-atlas-mailer-secret"

# Session Management
MAX_SESSIONS_PER_USER=3

# Rate Limiting
MAX_READINGS_PER_DAY=20
MAX_UPLOADS_PER_DAY=60
# Observability
OBSERVABILITY_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
# GRAFANA_CLOUD_INSTANCE_ID=
# GRAFANA_CLOUD_API_KEY=