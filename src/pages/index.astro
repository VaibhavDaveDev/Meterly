---
import '../styles/globals.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="Meterly" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Meterly calculates solar-adjusted electricity bills transparently to replace manual spreadsheets." />
    <meta name="google-site-verification" content="4J-BdPn3CVPK5uJmfdmZ90FeOQBu-iwOaENyirsc1PQ" />
    <title>Meterly: Transparent electricity bills</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@600&family=Manrope:wght@600;700;800&family=Work+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Theme: read preference before render to prevent flash -->
    <script is:inline>
      (function () {
        const saved = localStorage.getItem('meterly-theme') || 'system';
        const isDark = saved === 'dark' || (saved === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
        document.documentElement.setAttribute('data-theme', isDark ? 'dark' : 'light');
        if (isDark) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      })();
    </script>
  </head>

  <body class="bg-background text-on-background font-body-md antialiased overflow-x-hidden selection:bg-primary-container selection:text-primary-fixed">
    <!-- TopNavBar -->
    <header class="bg-surface/80 backdrop-blur-md w-full top-0 sticky z-50 border-b border-outline-variant/30 shadow-sm transition-all duration-300">
      <div class="flex justify-between items-center h-20 px-margin-mobile md:px-margin-desktop max-w-container-max mx-auto">
        <a class="text-2xl font-headline-lg text-primary tracking-tight flex items-center gap-2 hover:opacity-80 transition-opacity" href="/">
          <div class="flex items-center justify-center flex-shrink-0">
            <img src="/favicon.svg" alt="Meterly Logo" class="w-8 h-8 rounded-lg" />
          </div>
          <span class="font-headline-lg font-bold">Meterly</span>
        </a>
        <nav class="hidden md:flex items-center gap-gutter">
          <a class="text-label-caps font-label-caps text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="#how-it-works">How it Works</a>
          <a class="text-label-caps font-label-caps text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="#features">Features</a>
          <a class="text-label-caps font-label-caps text-on-surface-variant hover:text-primary-container transition-colors duration-200" href="#testimonials">Testimonials</a>
        </nav>
        <div class="flex items-center gap-3">
          <button id="theme-toggle" aria-label="Toggle theme" class="p-2 rounded-full hover:bg-surface-container transition-colors text-on-surface-variant">
            <span class="material-symbols-outlined dark:hidden">light_mode</span>
            <span class="material-symbols-outlined hidden dark:block">dark_mode</span>
          </button>
          <a class="hidden md:inline-flex font-label-caps text-label-caps text-on-surface-variant hover:text-primary transition-colors duration-200 px-4 py-3" href="/login">
            Sign in
          </a>
          <a class="bg-primary hover:bg-primary-container hover:text-on-primary-container text-on-primary font-label-caps text-label-caps px-6 py-3 rounded-full transition-transform duration-200 hover:scale-105 active:scale-95 shadow-md hover:shadow-lg" href="/signup">
            Sign up
          </a>
        </div>
      </div>
      <!-- Mobile drawer (suppressed signup since it is now always visible) -->
      <div id="mobile-menu" class="hidden px-margin-mobile pb-4 pt-2 bg-surface border-t border-outline-variant/30 md:hidden">
        <a href="/login" class="block py-2 text-label-caps font-label-caps text-on-surface-variant hover:text-primary-container transition-colors duration-200 text-center">Sign in</a>
      </div>
    </header>

    <main>
        <!-- Hero Section -->
        <section class="relative pt-stack-lg pb-stack-lg md:pt-[120px] md:pb-[160px] overflow-hidden">
            <div class="absolute inset-0 z-0">
                <img alt="Modern eco-friendly house with integrated solar panels" class="w-full h-full object-cover" src="/house.png">
                <div class="absolute inset-0 bg-background/90 md:bg-gradient-to-r md:from-background md:via-background/80 md:to-transparent z-10">
                </div>
                <!-- Mobile dark mode gradient to ensure white text is readable against the bright sky -->
                <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-transparent hidden dark:block md:hidden z-10"></div>
            </div>
            <div class="relative z-10 max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop grid grid-cols-1 lg:grid-cols-12 gap-gutter items-center">
                <div class="lg:col-span-6 flex flex-col gap-stack-md">
                    <div class="inline-flex items-center gap-2 bg-surface-container-high px-4 py-2 rounded-full w-fit border border-outline-variant/30">
                        <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">bolt</span>
                        <span class="font-label-caps text-label-caps text-primary">Intelligent Utility Management</span>
                    </div>
                    <h1 class="font-headline-xl text-headline-xl text-on-background tracking-tight dark:drop-shadow-lg">
                        <span class="text-[#0a3a2a] dark:text-white">Solar Billing,</span> <br> <span class="text-[#4edea3] dark:text-primary italic">Simplified.</span>
                    </h1>
                    <p class="font-body-md text-body-md text-on-surface-variant max-w-lg">
                        Stop struggling with Excel. Meterly automates complex solar calculations for landlords and tenants with 100% transparency and precision.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 pt-4">
                        <a href="/signup" class="bg-primary text-on-primary font-label-caps text-label-caps px-8 py-4 rounded-full shadow-[0_8px_30px_rgb(0,53,39,0.15)] hover:shadow-[0_8px_30px_rgb(0,53,39,0.25)] hover:-translate-y-0.5 transition-all duration-200 flex items-center justify-center gap-2">
                            Start Tracking
                            <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                        </a>
                        <a href="#how-it-works" class="bg-surface border-2 border-primary text-primary font-label-caps text-label-caps px-8 py-4 rounded-full hover:bg-surface-container transition-colors duration-200 flex items-center justify-center gap-2">
                            View Sample Bill
                            <span class="material-symbols-outlined text-[18px]">receipt_long</span>
                        </a>
                    </div>
                    <div class="flex items-center gap-4 mt-8 opacity-80">
                        <div class="flex -space-x-3">
                            <div class="w-8 h-8 rounded-full bg-primary-container border-2 border-surface flex items-center justify-center">
                                <span class="material-symbols-outlined text-on-primary text-xs">person</span>
                            </div>
                            <div class="w-8 h-8 rounded-full bg-secondary-container border-2 border-surface flex items-center justify-center">
                                <span class="material-symbols-outlined text-on-secondary-container text-xs">person</span>
                            </div>
                            <div class="w-8 h-8 rounded-full bg-tertiary-container border-2 border-surface flex items-center justify-center">
                                <span class="material-symbols-outlined text-on-tertiary-container text-xs">person</span>
                            </div>
                        </div>
                        <span class="font-label-caps text-[10px] text-on-surface-variant uppercase tracking-wider">Trusted by 500+ Properties</span>
                    </div>
                </div>
                <div class="lg:col-span-6 relative mt-12 lg:mt-0">
                    <!-- Abstract Data Visualization / Glass Card -->
                    <div class="relative w-full aspect-square max-w-[500px] ml-auto">
                        <div class="absolute inset-0 bg-primary/5 rounded-full blur-3xl animate-pulse"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- How It Works Section -->
        <section class="py-stack-lg bg-surface-container-lowest" id="how-it-works">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="text-center max-w-2xl mx-auto mb-16">
                    <h2 class="font-headline-xl text-headline-xl text-on-background mb-4">Effortless Workflow</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant">From setup to settlement, Meterly streamlines the entire process, eliminating manual errors and disputes.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <!-- Step 1 -->
                    <div class="group relative bg-surface border border-surface-variant rounded-xl p-8 hover:shadow-[0_8px_30px_rgb(0,53,39,0.08)] transition-all duration-300 hover:-translate-y-1">
                        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                            <span class="font-data-point text-6xl text-primary font-bold">01</span>
                        </div>
                        <div class="w-12 h-12 bg-primary-container/10 rounded-full flex items-center justify-center mb-6 text-primary">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">home_work</span>
                        </div>
                        <h3 class="font-headline-lg text-xl mb-3 text-on-background">Create your property</h3>
                        <p class="font-body-sm text-body-sm text-on-surface-variant">Setup your home details and solar meter specifications in minutes. Simple, secure, and fast.</p>
                    </div>
                    <!-- Step 2 -->
                    <div class="group relative bg-surface border border-surface-variant rounded-xl p-8 hover:shadow-[0_8px_30px_rgb(0,53,39,0.08)] transition-all duration-300 hover:-translate-y-1">
                        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                            <span class="font-data-point text-6xl text-primary font-bold">02</span>
                        </div>
                        <div class="w-12 h-12 bg-primary-container/10 rounded-full flex items-center justify-center mb-6 text-primary">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">person_add</span>
                        </div>
                        <h3 class="font-headline-lg text-xl mb-3 text-on-background">Invite your tenant</h3>
                        <p class="font-body-sm text-body-sm text-on-surface-variant">Add your tenant's contact information and establish the energy split percentage upfront.</p>
                    </div>
                    <!-- Step 3 -->
                    <div class="group relative bg-surface border border-surface-variant rounded-xl p-8 hover:shadow-[0_8px_30px_rgb(0,53,39,0.08)] transition-all duration-300 hover:-translate-y-1">
                        <div class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
                            <span class="font-data-point text-6xl text-primary font-bold">03</span>
                        </div>
                        <div class="w-12 h-12 bg-primary-container/10 rounded-full flex items-center justify-center mb-6 text-primary">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">input</span>
                        </div>
                        <h3 class="font-headline-lg text-xl mb-3 text-on-background">Submit readings</h3>
                        <p class="font-body-sm text-body-sm text-on-surface-variant">Input three simple numbers monthly: Total Solar Generation, Grid Export, and Grid Import.</p>
                    </div>
                    <!-- Step 4 -->
                    <div class="group relative bg-primary-container border border-primary rounded-xl p-8 shadow-md transform scale-105 z-10">
                        <div class="absolute top-0 right-0 p-4 opacity-20">
                            <span class="font-data-point text-6xl text-[#4edea3] dark:text-primary font-bold">04</span>
                        </div>
                        <div class="w-12 h-12 bg-primary/20 rounded-full flex items-center justify-center mb-6 text-primary">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">receipt_long</span>
                        </div>
                        <h3 class="font-headline-lg text-xl mb-3 text-on-primary-container">Bills are ready</h3>
                        <p class="font-body-sm text-body-sm text-on-primary-container opacity-80">Everyone receives a clear, math-verified bill instantly. Complete transparency, zero disputes.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Feature: The Transparent Bill -->
        <section class="py-stack-lg bg-surface overflow-hidden" id="features">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <!-- Content -->
                    <div>
                        <div class="inline-flex items-center gap-2 bg-surface-container-high px-3 py-1.5 rounded-full mb-6 border border-outline-variant/30">
                            <span class="material-symbols-outlined text-primary text-[16px]">visibility</span>
                            <span class="font-label-caps text-[10px] text-primary uppercase tracking-widest">The Transparent Bill</span>
                        </div>
                        <h2 class="font-headline-xl text-headline-xl text-on-background mb-6">Clarity in every calculation.</h2>
                        <p class="font-body-md text-body-md text-on-surface-variant mb-8">
                            We've redesigned the utility bill from the ground up. No hidden fees, no confusing jargon—just straightforward math that both landlords and tenants can trust.
                        </p>
                        <ul class="space-y-6">
                            <li class="flex gap-4">
                                <div class="mt-1 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 text-primary">
                                    <span class="material-symbols-outlined text-[16px]">check</span>
                                </div>
                                <div>
                                    <h4 class="font-label-caps text-label-caps text-on-background mb-1">Clear Solar Breakdown</h4>
                                    <p class="font-body-sm text-body-sm text-on-surface-variant">Instantly see the exact calculation: Solar Generated minus Export equals Self-Consumed energy.</p>
                                </div>
                            </li>
                            <li class="flex gap-4">
                                <div class="mt-1 w-6 h-6 rounded-full bg-primary/10 flex items-center justify-center flex-shrink-0 text-primary">
                                    <span class="material-symbols-outlined text-[16px]">check</span>
                                </div>
                                <div>
                                    <h4 class="font-label-caps text-label-caps text-on-background mb-1">Real-time Status Tracking</h4>
                                    <p class="font-body-sm text-body-sm text-on-surface-variant">Visual indicators let you know exactly what's paid and what's pending, keeping everyone aligned.</p>
                                </div>
                            </li>
                        </ul>
                    </div>
                    <!-- Bill Mockup -->
                    <div class="relative">
                        <!-- Decorative background elements -->
                        <div class="absolute -inset-4 bg-gradient-to-tr from-surface-container to-surface-container-high rounded-2xl transform rotate-3 z-0">
                        </div>
                        <!-- The Bill Card -->
                        <div class="relative bg-surface-container-lowest border border-surface-variant rounded-xl shadow-[0_20px_50px_rgb(0,53,39,0.1)] p-8 z-10">
                            <!-- Header -->
                            <div class="flex justify-between items-start mb-6 pb-4 border-b border-surface-variant">
                                <div>
                                    <h3 class="font-headline-lg text-xl text-on-background">Utility Statement</h3>
                                    <p class="font-label-caps text-[10px] text-on-surface-variant mt-1">JUNE 2025 • APARTMENT 4B</p>
                                </div>
                                <div class="bg-[#dcfce7] text-[#166534] px-3 py-1 rounded-sm font-label-caps text-[10px] border border-[#bbf7d0] tracking-widest font-bold">
                                    PAID
                                </div>
                            </div>
                            <!-- Meter Readings Table -->
                            <div class="mb-6">
                                <h4 class="font-label-caps text-[10px] text-on-surface-variant mb-3 uppercase tracking-widest">Meter Readings (kWh)</h4>
                                <div class="grid grid-cols-4 gap-2 text-[10px] font-label-caps text-on-surface-variant border-b border-surface-variant pb-1 mb-2">
                                    <span class="">Category</span>
                                    <span class="text-right">Start</span>
                                    <span class="text-right">End</span>
                                    <span class="text-right">Change</span>
                                </div>
                                <div class="space-y-2">
                                    <div class="grid grid-cols-4 gap-2 text-xs">
                                        <span class="text-on-background">Solar Gen</span>
                                        <span class="text-right opacity-60">3,005</span>
                                        <span class="text-right opacity-60">3,469</span>
                                        <span class="text-right font-bold">464</span>
                                    </div>
                                    <div class="grid grid-cols-4 gap-2 text-xs">
                                        <span class="text-on-background">Export</span>
                                        <span class="text-right opacity-60">2,690</span>
                                        <span class="text-right opacity-60">3,110</span>
                                        <span class="text-right font-bold">420</span>
                                    </div>
                                    <div class="grid grid-cols-4 gap-2 text-xs">
                                        <span class="text-on-background">Import</span>
                                        <span class="text-right opacity-60">605</span>
                                        <span class="text-right opacity-60">709</span>
                                        <span class="text-right font-bold">104</span>
                                    </div>
                                </div>
                            </div>
                            <!-- Solar Breakdown -->
                            <div class="mb-6 p-4 bg-primary/5 rounded-lg border border-primary/10">
                                <h4 class="font-label-caps text-[10px] text-primary mb-3 uppercase tracking-widest">Energy Math</h4>
                                <div class="space-y-1 text-xs">
                                    <div class="flex justify-between"><span class="">Solar Generated</span><span class="">464 units</span></div>
                                    <div class="flex justify-between text-secondary"><span class="">(-) Exported to Grid</span><span class="">420 units</span></div>
                                    <div class="flex justify-between font-bold border-t border-primary/10 pt-1 mt-1">
                                        <span class="">Solar Self-Consumed</span><span class="">44 units</span>
                                    </div>
                                    <div class="flex justify-between"><span class="">(+) Imported from Grid</span><span class="">104 units</span></div>
                                    <div class="flex justify-between font-bold text-primary text-sm pt-1"><span class="">Total Consumption</span><span class="">148 units</span></div>
                                </div>
                            </div>
                            <!-- Tenant Bill -->
                            <div class="bg-surface-container p-5 rounded-lg border border-surface-variant/50 mb-4">
                                <div class="flex justify-between items-center mb-3">
                                    <h4 class="font-label-caps text-[10px] text-on-surface-variant uppercase tracking-widest">Tenant's Share (50%)</h4>
                                    <span class="text-[10px] font-bold text-primary">74 units</span>
                                </div>
                                <div class="space-y-1 text-xs mb-3">
                                    <div class="flex justify-between"><span class="">Consumption (74 × ₹7.50)</span><span class="">₹555.00</span></div>
                                    <div class="flex justify-between"><span class="">Water Fixed Charge</span><span class="">₹200.00</span></div>
                                </div>
                                <div class="flex justify-between items-center pt-2 border-t border-surface-variant">
                                    <span class="font-body-md text-on-background font-bold">Total Due</span>
                                    <span class="font-data-point text-2xl text-primary">₹755.00</span>
                                </div>
                            </div>
                            <!-- Owner Credit -->
                            <div class="px-2">
                                <div class="flex justify-between items-center text-[10px] font-label-caps text-on-surface-variant">
                                    <span class="">Owner's Export Credit</span>
                                    <span class="italic">(420 × ₹2.50) - ₹15 = ₹1,035.00</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Visual Insights Section -->
        <section class="py-stack-lg bg-surface-container-low overflow-hidden" id="visual-insights">
            <div class="max-w-container-max mx-auto px-margin-mobile md:px-margin-desktop">
                <div class="text-center max-w-2xl mx-auto mb-16">
                    <div class="inline-flex items-center gap-2 bg-primary/5 px-3 py-1.5 rounded-full mb-4 border border-primary/10">
                        <span class="material-symbols-outlined text-primary text-[16px]">analytics</span>
                        <span class="font-label-caps text-[10px] text-primary uppercase tracking-widest">Dashboard Preview</span>
                    </div>
                    <h2 class="font-headline-xl text-headline-xl text-on-background mb-4">Visual Insights for Everyone</h2>
                    <p class="font-body-md text-body-md text-on-surface-variant">Real-time data visualization that makes sense of your energy production and consumption patterns.</p>
                </div>
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-gutter">
                    <div class="lg:col-span-8 bg-surface-container-lowest border border-surface-variant/50 rounded-2xl p-8 shadow-sm">
                        <div class="flex justify-between items-center mb-8">
                            <h3 class="font-headline-lg text-xl text-on-background">Consumption Trends</h3>
                            <div class="flex gap-4">
                                <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-primary"></span><span class="text-xs font-label-caps text-on-surface-variant">Solar</span></div>
                                <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-secondary-container"></span><span class="text-xs font-label-caps text-on-surface-variant">Grid</span></div>
                            </div>
                        </div>
                        <div class="h-[240px] flex items-end justify-between gap-4 mb-12">
                            <div class="flex flex-col justify-between h-40 mb-6 text-[10px] font-label-caps text-on-surface-variant text-right">
                                <span>600<span class="hidden sm:inline"> units</span></span>
                                <span>300<span class="hidden sm:inline"> units</span></span>
                                <span>0<span class="hidden sm:inline"> units</span></span>
                            </div>
                            <div class="flex-1 flex flex-col gap-2">
                                <div class="flex items-end gap-1 h-40">
                                    <div class="bg-primary w-full rounded-t-sm" style="height: 45%"></div>
                                    <div class="bg-secondary-container w-full rounded-t-sm" style="height: 25%"></div>
                                </div><span class="text-[10px] font-label-caps text-center">JAN</span>
                            </div>
                            <div class="flex-1 flex flex-col gap-2">
                                <div class="flex items-end gap-1 h-40">
                                    <div class="bg-primary w-full rounded-t-sm" style="height: 55%"></div>
                                    <div class="bg-secondary-container w-full rounded-t-sm" style="height: 35%"></div>
                                </div><span class="text-[10px] font-label-caps text-center">FEB</span>
                            </div>
                            <div class="flex-1 flex flex-col gap-2">
                                <div class="flex items-end gap-1 h-40">
                                    <div class="bg-primary w-full rounded-t-sm" style="height: 40%"></div>
                                    <div class="bg-secondary-container w-full rounded-t-sm" style="height: 45%"></div>
                                </div><span class="text-[10px] font-label-caps text-center">MAR</span>
                            </div>
                            <div class="flex-1 flex flex-col gap-2">
                                <div class="flex items-end gap-1 h-40">
                                    <div class="bg-primary w-full rounded-t-sm" style="height: 65%"></div>
                                    <div class="bg-secondary-container w-full rounded-t-sm" style="height: 20%"></div>
                                </div><span class="text-[10px] font-label-caps text-center">APR</span>
                            </div>
                            <div class="flex-1 flex flex-col gap-2">
                                <div class="flex items-end gap-1 h-40">
                                    <div class="bg-primary w-full rounded-t-sm" style="height: 80%"></div>
                                    <div class="bg-secondary-container w-full rounded-t-sm" style="height: 15%"></div>
                                </div><span class="text-[10px] font-label-caps text-center">MAY</span>
                            </div>
                            <div class="flex-1 flex flex-col gap-2">
                                <div class="flex items-end gap-1 h-40">
                                    <div class="bg-primary w-full rounded-t-sm" style="height: 75%"></div>
                                    <div class="bg-secondary-container w-full rounded-t-sm" style="height: 10%"></div>
                                </div><span class="text-[10px] font-label-caps text-center">JUN</span>
