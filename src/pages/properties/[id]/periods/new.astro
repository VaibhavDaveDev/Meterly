---
import '../../../../styles/globals.css';
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import { CreatePeriodForm } from '../../../../components/meter/CreatePeriodForm';

const { id } = Astro.params;
const isPast = Astro.url.searchParams.get('past') === 'true';
---

<DashboardLayout title="Create Period - Meterly">
  <div class="max-w-2xl mx-auto space-y-6">
    <div class="space-y-1">
      <a href={`/properties/${id}`} class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-foreground transition-colors mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to Property
      </a>
      <h1 class="text-2xl font-bold tracking-tight">
        {isPast ? 'Add Past Period Data' : 'Create New Period'}
      </h1>
      <p class="text-muted-foreground mt-1 font-body">
        {isPast 
          ? 'Enter historical meter readings for a previous month'
          : 'Start a new billing period'
        }
      </p>
    </div>
    
    <CreatePeriodForm 
      client:only="react" 
      propertyId={id as string}
      isPastEntry={isPast}
    />
  </div>
</DashboardLayout>
